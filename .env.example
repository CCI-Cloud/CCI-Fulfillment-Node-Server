NODE_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Public application URLs. Do not include a trailing slash.
CCI_APP_HOME=https://app.example.com
PROVIDER_DOMAIN=.example.com
REDIRECT_URI=https://api.example.com/callback

# NetSuite OAuth and REST configuration.
CLIENT_ID=
CLIENT_SECRET=
OAUTH_STEP_ONE_GET_ENDPOINT=
OAUTH_STEP_TWO_POST_ENDPOINT=
SCOPE=
POST_HEADER_CONTENT_TYPE=application/x-www-form-urlencoded
CCI_NETSUITE_REST_ROOT_URI=
CCI_NETSUITE_SUITEQL_ROOT_URI=

# Request limiting.
RATE_LIMIT_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging. Hostinger must allow writes to these relative paths.
INFO_LOG_LEVEL=info
DEBUG_LOG_LEVEL=debug
ERROR_LOG_LEVEL=error
SERVICE_NAME=cci-node-server
ERROR_LOG_PATH=logs/error.log
COMBINED_LOG_PATH=logs/combined.log

# IDrive e2-compatible object storage.
IDRIVE_ACCESS_KEY_ID=
IDRIVE_SECRET_ACCESS_KEY=
IDRIVE_S3_REGION=
IDRIVE_S3_ACL=public-read
IDRIVE_S3_ENDPOINT=
IDRIVE_S3_BUCKET_NAME=
IDRIVE_S3_PICTURES_FOLDER=
IDRIVE_S3_SIGNATURES_FOLDER=
IDRIVE_S3_PUBLIC_ENDPOINT=
IMAGE_NAMES_SEPARATOR=,
